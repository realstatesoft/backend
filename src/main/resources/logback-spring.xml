<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <include resource="org/springframework/boot/logging/logback/defaults.xml"/>
    <include resource="org/springframework/boot/logging/logback/console-appender.xml"/>

    <!-- Archivo principal de logs -->
    <property name="LOG_FILE" value="logs/openroof.log"/>
    <!-- Archivo separado solo para Alertas -->
    <property name="ALERTS_LOG_FILE" value="logs/property-alerts.log"/>

    <!-- Appender para el archivo general -->
    <appender name="ROLLING-FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <encoder>
            <pattern>${FILE_LOG_PATTERN}</pattern>
        </encoder>
        <file>${LOG_FILE}</file>
        <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
            <fileNamePattern>${LOG_FILE}.%d{yyyy-MM-dd}.%i.gz</fileNamePattern>
            <maxFileSize>10MB</maxFileSize>
            <maxHistory>7</maxHistory>
        </rollingPolicy>
    </appender>

    <!-- Appender específico para el archivo de Alertas -->
    <appender name="ALERTS-FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level %logger{36} - %msg%n</pattern>
        </encoder>
        <file>${ALERTS_LOG_FILE}</file>
        <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
            <fileNamePattern>${ALERTS_LOG_FILE}.%d{yyyy-MM-dd}.%i.gz</fileNamePattern>
            <maxFileSize>5MB</maxFileSize>
            <maxHistory>30</maxHistory>
        </rollingPolicy>
    </appender>

    <!-- Redirigir el Scheduler a su propio archivo y a la Consola -->
    <!-- additivity="false" evita que los logs se dupliquen en el root logger (openroof.log) -->
    <logger name="com.openroof.openroof.scheduler.PropertyAlertScheduler" level="INFO" additivity="false">
        <appender-ref ref="ALERTS-FILE"/>
        <appender-ref ref="CONSOLE"/>
    </logger>

    <!-- Root logger: todo lo demás va a la consola y al archivo general -->
    <root level="INFO">
        <appender-ref ref="CONSOLE"/>
        <appender-ref ref="ROLLING-FILE"/>
    </root>
</configuration>
