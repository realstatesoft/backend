# Copy this file to .env and fill in the values.
# .env is gitignored — never commit real secrets.

# PostgreSQL (Supabase pooler)
DB_URL=jdbc:postgresql://<host>:6543/postgres?prepareThreshold=0&sslmode=require
DB_USER=postgres.<project-ref>
DB_PASS=

# JWT
JWT_SECRET=
JWT_EXPIRATION=86400000
JWT_REFRESH_EXPIRATION=604800000

# Supabase Storage
SUPABASE_URL=https://<project-ref>.storage.supabase.co/storage/v1/s3
SUPABASE_KEY=
SUPABASE_STORAGE_BUCKET=openroof-images-test

# Mail (optional)
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=

# Server
SERVER_PORT=8080
CORS_ALLOWED_ORIGINS=http://localhost:5173
